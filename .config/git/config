[user]
  name = Gabriel Nascimento
  email = 135087316+gabrielgnsilva@users.noreply.github.com
  signingkey = ~/.ssh/git_signingkey.pub

[gpg]
  format = ssh

[credential]
  helper = /usr/lib/git-core/git-credential-libsecret

[init]
  defaultBranch = main

[core]
  editor = nvim
  autocrlf = input

[color]
  ui = true

[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = red bold 52
    newNormal = green bold
    newHighlight = green bold 22

[color "diff"]
  meta = 11
  frag = magenta bold
  func = 146 bold
  commit = yellow bold
  old = red bold
  new = green bold
  whitespace = red reverse

[color "blame"]
    highlightRecent = black bold,1 year ago,white,1 month ago,default,7 days ago,blue

[color "branch"]
    current  = magenta
    local    = default
    remote   = yellow
    upstream = green
    plain    = blue

[color.decorate]
    HEAD = red
    branch = blue
    tag = yellow
    remoteBranch = magenta

[log]
    abbrevCommit = true  # short commits
    graphColors  = blue,yellow,cyan,magenta,green,red

[url "git@github.com:"]
  insteadOf = "github:"

[url "git@github.com:gabrielgnsilva/"]
  insteadOf = "repo:"

[alias]
  hist = log --graph --decorate --all --pretty=format:'%C(magenta)%h %C(white) %an %ar%C(auto) %D%n%s%n'
  last = log -1 HEAD
  patch = !git --no-pager diff --no-color
  unstage = reset HEAD --
  undo = reset --soft HEAD~1
  diff = diff --color
  review = push -o mr.target=main

[pager]
  diff = "diff-so-fancy | less --tabs=4 -RFXS --pattern '^(Date|added|deleted|modified): '"
  branch = false
  tag = false

[commit]
  gpgsign = true
  template = ~/.config/git/template
  verbose = true

[tag]
  gpgsign = true
  sort = -taggerdate

[branch]
  sort = -committerdate

[pull]
  rebase = true

[push]
  default = simple
  autoSetupRemote = true

[rebase]
  autoStash = true
  missingCommitsCheck = warn

[merge]
  conflictstyle = diff3

[status]
  showUntrackedFiles = no

[advice]
  addIgnoredFile = false

[diff]
  tool = nvimdiff

[difftool "nvimdiff"]
  cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""

[difftool]
  prompt = false

[interactive]
  diffFilter = "diff-so-fancy --patch"
  singlekey = true
