sort=-time
layer=overlay
background-color=#26233a
width=300
height=300
border-size=2
border-color=#524f67
border-radius=10
padding=3
margin=10
outer-margin=20
icons=0
max-icon-size=64
default-timeout=7000
ignore-timeout=1
font=JetBrains Mono 12
text-color=#e0def4
on-button-right=dismiss-all

[mode=do-not-disturb]
invisible=1

[urgency=low]
border-color=#524f67

[urgency=normal]
border-color=#ebbcba

[urgency=high]
border-color=#eb6f92
default-timeout=0

[category=mpd]
default-timeout=2000
group-by=category

[app-name=Volume-App]
layer=overlay
history=0
anchor=top-center
group-by=app-name
format=<b>%s</b>\n%b
progress-color=#eb6f92
[mode=do-not-disturb]
invisible=1

[app-name=Volume-App grouped=false]
# Force initial volume notification to be visible
invisible=0

[app-name=volume group-index=0]
# Only show last notification
invisible=0
