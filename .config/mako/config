background-color=#1e1e2e
text-color=#cdd6f4
border-color=#b4befe
progress-color=over #313244

sort=-time
layer=overlay
width=300
height=300
border-size=1
border-radius=0
padding=10
margin=10
outer-margin=20
icons=0
max-icon-size=64
default-timeout=7000
ignore-timeout=1
font=JetBrains Mono Bold 12
on-button-right=dismiss-all

[urgency=high]
border-color=#f38ba8
default-timeout=0

[mode=do-not-disturb]
invisible=1

[category=mpd]
default-timeout=2000
group-by=category

[app-name=Volume-App]
layer=overlay
history=0
anchor=top-center
group-by=app-name
format=<b>%s</b>\n%b
[mode=do-not-disturb]
invisible=1

[app-name=Volume-App grouped=false]
# Force initial volume notification to be visible
invisible=0

[app-name=volume group-index=0]
# Only show last notification
invisible=0
