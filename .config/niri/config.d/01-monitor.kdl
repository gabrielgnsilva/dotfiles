output "DP-1" {
    mode "2560x1440@180.002"
    scale 1
    transform "normal"
    position x=1080 y=0
    hot-corners { off; }
    focus-at-startup;
    variable-refresh-rate on-demand=true
}

output "DP-2" {
    mode "1920x1080@165.003"
    scale 1
    transform "270"
    position x=0 y=0
    hot-corners { off; }
    variable-refresh-rate on-demand=true
}
