{
  "htmlWhitespaceSensitivity": "ignore",
  "insertPragma": true,
  "jsxSingleQuote": true,
  "singleQuote": true,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "es5",
  "overrides": [
    {
      "files": "*.ftl",
      "options": {
        "parser": "html"
      }
    },
    {
      "files": "*.md",
      "options": {
        "printWidth": 80
      }
    }
  ]
}
