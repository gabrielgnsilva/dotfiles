#!/usr/bin/env sh

set -eu

usage() {
  {
    printf "Usage: %s <branch-name> [--closes-issue|-c <issue-number>] [commit-message]\n" "$(basename "${0}")"
    printf "\n"
    printf "Arguments:\n"
    printf "  branch-name         Name of the branch to create (required)\n"
    printf "  --closes-issue, -c  Optional flag to indicate that the commit message should include a 'closes #<issue-number>' prefix\n"
    printf "  issue-number        The issue number to include in the commit message (required if --closes-issue or -c is used)\n"
    printf "  commit-message      The commit message to use (optional; if not provided, the branch name will be used)\n"
    printf "\n"
    printf "Examples:\n"
    printf "  %s feature/add-login --closes-issue 42 \"Add login functionality\"\n" "$(basename "${0}")"
    printf "  %s bugfix/fix-crash  -c 101\n" "$(basename "${0}")"
    printf "  %s docs/update-readme \"Update README with new instructions\"\n" "$(basename "${0}")"
  }
}

prettify_branch() {
  printf "%s" "${1}" | sed 's/-/: /1' | tr '-' ' '
}

ask_issue_number() {
  printf "Enter issue number: " >&2
  read -r nr
  while [ -z "${nr}" ] || ! printf "%s" "${nr}" | grep -qE '^[0-9]+$'; do
    printf "Issue number must be a non-empty numeric value. Please enter a valid issue number: " >&2
    read -r nr
  done
  printf "%s" "${nr}"
}

main() {
  closes_issue=0
  add_all=0
  issue_number=""
  branch=""
  commit=""

  [ "${#}" -lt 1 ] && {
    usage
    exit 1
  }

  branch="${1}"
  shift # Branch name is first argument
  if printf "%s" "${branch}" | grep -q " "; then
    printf "Invalid branch: contains spaces.\n"
    exit 1
  fi

  while [ "${#}" -gt 0 ]; do
    case "${1}" in
      -h | --help)
        usage
        exit 0
        ;;
      -a | --all)
        add_all=1
        shift
        ;;
      -c | --closes-issue)
        closes_issue=1
        shift
        if [ "${#}" -gt 0 ] && printf "%s" "${1}" | grep -qE '^[0-9]+$'; then
          issue_number="${1}"
        else
          issue_number="$(ask_issue_number)"
        fi
        ;;
      --)
        shift
        break
        ;;
      -*)
        printf "Unknown option: %s\n" "${1}"
        usage
        exit 1
        ;;
      *)
        if [ -z "${commit}" ]; then
          commit="${1}"
        else
          commit="${commit} ${1}"
        fi
        shift
        ;;
    esac
  done

  [ -z "${commit}" ] && commit="$(prettify_branch "${branch}")"
  [ "${closes_issue}" -eq 1 ] && commit="${commit} - closes #${issue_number}"

  printf "About to run the following git commands:\n"
  [ "${add_all}" -eq 1 ] && printf "  git add .\n"
  printf "  git checkout -b \"%s\"\n" "${branch}"
  printf "  git commit -m \"%s\"\n" "${commit}"
  printf "\nProceed? (y/n): " >&2
  read -r confirm
  if ! printf "%s" "${confirm}" | grep -iqE '^(y|yes)$'; then
    printf "Aborted by user.\n"
    exit 0
  fi

  [ "${add_all}" -eq 1 ] && git add .
  git checkout -b "${branch}" \
    && git commit -m "${commit}" \
    && git push
}

if ! (return 0 2> /dev/null); then
  main "${@}"
fi
